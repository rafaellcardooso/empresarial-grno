[Unit]
Description=SIR ingest — Alertas RAL (Playwright)
After=network.target mariadb.service

[Service]
Type=simple
User=datacenter
Group=datacenter
WorkingDirectory=/usr/local/empresarial/workers/sir-ingest
Environment=PATH=/usr/bin:/usr/local/bin
Environment=TMPDIR=/usr/local/empresarial/workers/sir-ingest/states/tmp
Environment=PLAYWRIGHT_BROWSERS_PATH=/usr/local/empresarial/workers/sir-ingest/.playwright-browsers
EnvironmentFile=/usr/local/empresarial/workers/sir-ingest/.env
ExecStart=/usr/bin/node sources/AlertasRalRede.js
Restart=always
RestartSec=30
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sir-ingest-ral

[Install]
WantedBy=multi-user.target
