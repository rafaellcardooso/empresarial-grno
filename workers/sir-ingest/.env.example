# SIR ingest worker — copie para .env
# cp .env.example .env
#
# SIR_DB_* deve ser igual ao .env.local da raiz (MySQL claroEmpresarial).
# Rodar na raiz: npm run env:check

# --- MySQL SIR (escrita worker) ---
SIR_DB_HOST=127.0.0.1
SIR_DB_PORT=3306
SIR_DB_USER=monitor
SIR_DB_PASSWORD=troque_me
SIR_DB_NAME=claroEmpresarial

# --- Telegram (bot — processo separado) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- SIR legado (Playwright) ---
SISTEMA_USUARIO=
SISTEMA_SENHA=
SISTEMA_URL=http://10.53.224.155/index.cfm?nofoc=yes
INTERVALO_MONITORAMENTO=300000
# CICLOS_VAZIOS_PARA_ENCERRAR=2

# --- Debug scrape ---
SAVE_SCRAPE_ERROR_HTML=true
MAX_SCRAPE_ERROR_DUMPS=5

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true

# --- Next.js BFF (bot consome estas rotas) ---
EMPRESARIAL_API_URL=http://127.0.0.1:3002/api
