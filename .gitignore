# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Production DB dumps (never commit)
backup_*.sql
/data/backups/*.sql

# SIR ingest secrets / runtime noise
workers/sir-ingest/.env
workers/sir-ingest/node_modules/
workers/sir-ingest/.env
workers/sir-ingest/states/error/
workers/sir-ingest/states/debug/
workers/sir-ingest/states/tmp/*
!workers/sir-ingest/states/tmp/.gitkeep
workers/sir-ingest/.playwright-browsers/
workers/sir-ingest/**/__pycache__/
workers/sir-ingest/RalDetail_*.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
