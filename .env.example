# Empresarial (Next.js) — copie para .env.local
# cp .env.example .env.local
#
# Rodar: npm run env:check

# --- MySQL SIR (RAL/REC) — leitura Next + mesmas credenciais no worker ---
# Mesmo usuário/senha MySQL do hfc-sls (HFC_DB_*).
#
# WSL + MariaDB local:
#   npm run db:bootstrap
#   npm run db:migrate && npm run db:import
SIR_DB_HOST=127.0.0.1
SIR_DB_PORT=3306
SIR_DB_USER=monitor
SIR_DB_PASSWORD=troque_me
SIR_DB_NAME=claroEmpresarial
#
# Docker (porta 3307):
#   docker compose -f docker-compose.dev.yml up -d && npm run db:setup
# SIR_DB_PORT=3307
# SIR_DB_ROOT_PASSWORD=root_dev

# --- MySQL hfc-sls (tbl_inventory_pme BSOD) — somente leitura ---
HFC_DB_HOST=127.0.0.1
HFC_DB_USER=monitor
HFC_DB_PASSWORD=troque_me
HFC_DB_NAME=hfc-sls

# --- App ---
PORT=3002
